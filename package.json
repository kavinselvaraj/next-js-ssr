{
  "name": "my-ssr-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev slicemachine --parallel",
    "dev:ibe": "turbo dev --filter=ibe-app",
    "dev:admin": "turbo dev --filter=admin-app",
    "build": "turbo build",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "prepare": "husky",
    "start": "turbo start",
    "slicemachine": "turbo slicemachine --filter=ibe-app"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,scss}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.4",
    "turbo": "^2.5.6"
  }
}
