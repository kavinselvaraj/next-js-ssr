{
  "type": "SharedSlice",
  "id": "hero_with_metrics_cards",
  "name": "HeroWithMetricsCards",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "description": "Hero section with headline, description, action buttons, and several statistical/metrics cards displayed in a row below the actions.",
      "version": "initial",
      "imageUrl": "",
      "docURL": "...",
      "primary": {
        "eyebrow": {
          "type": "Text",
          "config": {
            "label": "Eyebrow"
          }
        },
        "headline": {
          "type": "StructuredText",
          "config": {
            "single": "heading1",
            "label": "Headline"
          }
        },
        "description": {
