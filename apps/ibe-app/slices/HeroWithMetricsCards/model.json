            "repeat": true,
            "variants": ["primary", "secondary"],
            "select": null
          }
        },
        "metrics": {
          "type": "Group",
          "config": {
            "label": "Metric Cards",
            "fields": {
              "metric_label": {
                "type": "Text",
                "config": {
                  "label": "Metric Label"
                }
              },
              "metric_value": {
                "type": "Text",
                "config": {
                  "label": "Metric Value"
                }
              }
            }
          }
        }
      }
    }
  ]
}
