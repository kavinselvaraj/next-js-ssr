{
  "format": "page",
  "id": "flight_page",
  "label": "Flight Page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "flight_code": {
        "type": "UID",
        "config": {
          "label": "Flight Code"
        }
      },
      "route_name": {
        "type": "Text",
        "config": {
          "label": "Route Name",
          "placeholder": "e.g. Dubai to London"
        }
      },
      "short_description": {
        "type": "Text",
        "config": {
          "label": "Short Description",
          "placeholder": "Brief flight details"
        }
      }
    }
  }
}
